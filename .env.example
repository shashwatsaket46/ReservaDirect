# ─────────────────────────────────────────────
# ReservaDirect — Environment Variables
# Copy to .env and fill in your keys.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── NVIDIA NIM (Agent brain + Menu OCR) ───────
# One key powers BOTH Nemotron agent loop AND nemotron-ocr-v1 menu scanning
# Get from: https://build.nvidia.com → any model → Get API Key
NVIDIA_API_KEY=nvapi-your-key-here

# ── ElevenLabs (WhatsApp + Voice) ─────────────
# Get from: https://elevenlabs.io → Conversational AI → API Keys
ELEVENLABS_API_KEY=sk_your-key-here
# Your ElevenLabs Conversational AI Agent ID (WhatsApp agent)
ELEVENLABS_AGENT_ID=agent_your-whatsapp-agent-id
# Your ElevenLabs Voice Agent ID (for outbound phone calls)
ELEVENLABS_VOICE_AGENT_ID=agent_your-voice-agent-id

# ── Twilio (Phone number for outbound calls) ──
# Get from: https://twilio.com → Account → Account Info
TWILIO_ACCOUNT_SID=ACyour-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Google Places (Restaurant search fallback) ─
# Get from: https://console.cloud.google.com → APIs → Places API
GOOGLE_PLACES_API_KEY=AIzaSy-your-key-here

# ── Databricks (Primary restaurant search) ────
# Get from: Databricks workspace → Settings → Developer → Access Tokens
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi-your-token-here
DATABRICKS_RESTAURANT_ENDPOINT=/serving-endpoints/restaurant-search/invocations

# ── Nia MCP (Legal compliance) ────────────────
# Get from: https://nozomio.com → Dashboard → API Keys
NIA_API_KEY=your-nia-key-here
NIA_MCP_URL=https://api.nozomio.com/mcp

# ── Supabase (Database + Auth) ────────────────
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Stripe (Payments — PCI handled by Stripe) ─
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── App Config ────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
# Set to "true" to stub external API calls (dev mode)
STUB_EXTERNAL_APIS=false
